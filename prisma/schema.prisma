// prisma/schema.prisma
// Wheelchair Rental Platform — Production Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Required for Vercel + Supabase/Neon pooling
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  CUSTOMER
  ADMIN
}

enum BookingStatus {
  PENDING    // Awaiting payment
  CONFIRMED  // Payment successful
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED  // Cancelled by user or admin
  COMPLETED  // Rental period ended
  EXPIRED    // Payment never completed (auto-expire)
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  ONLINE
  CASH
}

enum BookingPaymentStatus {
  PENDING
  PAID
  EXPIRED
}

enum WheelchairStatus {
  AVAILABLE
  MAINTENANCE
  RETIRED
}

enum WheelchairCategory {
  STANDARD
  ELECTRIC
  PEDIATRIC
  BARIATRIC
  TRANSPORT
}

enum DeliveryCity {
  DUBAI
  SHARJAH
  AJMAN
  UAQ
  ABU_DHABI
  RAK
  FUJAIRAH
  AL_AIN
}

enum DeliveryWindow {
  MORNING
  AFTERNOON
  EVENING
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  role          Role      @default(CUSTOMER)
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  bookings      Booking[]
  invoices      Invoice[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// ─────────────────────────────────────────────
// WHEELCHAIR
// ─────────────────────────────────────────────

model Wheelchair {
  id            String             @id @default(cuid())
  name          String
  nameAr        String             // Arabic name
  description   String
  descriptionAr String             // Arabic description
  category      WheelchairCategory @default(STANDARD)
  status        WheelchairStatus   @default(AVAILABLE)
  pricePerDay   Decimal            @db.Decimal(10, 2)
  stockQuantity Int                @default(1)
  images        String[]           // Array of image URLs
  features      String[]           // Feature tags (e.g., "foldable", "lightweight")
  featuresAr    String[]           // Arabic features
  weight        Float?             // kg
  maxLoad       Float?             // kg
  serialNumber  String             @unique
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  // Relations
  bookings      Booking[]

  @@index([status])
  @@index([category])
  @@index([pricePerDay])
  @@map("wheelchairs")
}

// ─────────────────────────────────────────────
// BOOKING
// ─────────────────────────────────────────────

model Booking {
  id              String        @id @default(cuid())
  userId          String
  wheelchairId    String
  startDate       DateTime      @db.Date
  endDate         DateTime      @db.Date
  totalDays       Int
  totalPrice      Decimal       @db.Decimal(10, 2)
  status          BookingStatus @default(PENDING)
  phoneNumber     String
  deliveryCity    DeliveryCity
  deliveryWindow  DeliveryWindow
  deliveryAddress String
  deliveryNotes   String?
  deliveryFee     Decimal       @db.Decimal(10, 2) @default(0)
  paymentMethod   PaymentMethod       @default(ONLINE)
  paymentStatus   BookingPaymentStatus @default(PENDING)
  reservationExpiresAt DateTime?
  paidAt          DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  user            User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  wheelchair      Wheelchair    @relation(fields: [wheelchairId], references: [id], onDelete: Restrict)
  payment         Payment?
  invoice         Invoice?

  // Composite index to speed up availability queries
  @@index([wheelchairId, startDate, endDate])
  @@index([userId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@map("bookings")
}

// ─────────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────────

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String        @unique
  stripePaymentIntentId String        @unique
  stripeCustomerId      String?
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("usd")
  status                PaymentStatus @default(PENDING)
  paidAt                DateTime?
  refundedAt            DateTime?
  refundAmount          Decimal?      @db.Decimal(10, 2)
  stripeRefundId        String?
  metadata              Json?         // Store raw Stripe metadata
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  // Relations
  booking               Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([stripePaymentIntentId])
  @@index([status])
  @@map("payments")
}

// ─────────────────────────────────────────────
// INVOICE
// ─────────────────────────────────────────────

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique // e.g., INV-2024-0001
  bookingId     String   @unique
  userId        String
  subtotal      Decimal  @db.Decimal(10, 2)
  taxRate       Decimal  @db.Decimal(5, 4) @default(0.05) // 5% VAT
  taxAmount     Decimal  @db.Decimal(10, 2)
  totalAmount   Decimal  @db.Decimal(10, 2)
  currency      String   @default("usd")
  issuedAt      DateTime @default(now())
  dueAt         DateTime
  pdfUrl        String?  // URL to generated PDF
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([invoiceNumber])
  @@index([issuedAt])
  @@map("invoices")
}

// ─────────────────────────────────────────────
// INVOICE COUNTER (for sequential numbering)
// ─────────────────────────────────────────────

model InvoiceCounter {
  id        Int      @id @default(1)
  year      Int
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("invoice_counters")
}
